      "provider": "opencode-go",
      "model_id": "glm-5.1",
      "temperature": 0.7,
      "max_tokens": 4096,
      "vision": true
    },
    "glm-5.2": {
      "provider": "opencode-go",
      "model_id": "glm-5.2",
      "temperature": 0.7,
      "max_tokens": 8192,
      "vision": false
    },
    "kimi-k2.7-code": {
      "provider": "opencode-go",
      "model_id": "kimi-k2.7-code",
      "temperature": 0.7,
      "max_tokens": 32768,
      "vision": true
    },
    "qwen3.7-plus": {
      "provider": "opencode-go",
      "model_id": "qwen3.7-plus",
      "temperature": 0.7,
      "max_tokens": 8192,
      "vision": true
